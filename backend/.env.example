# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# OpenAI
OPENAI_API_KEY=your-openai-api-key

# LINE Messaging API
LINE_CHANNEL_ACCESS_TOKEN=your-line-channel-access-token
LINE_CHANNEL_SECRET=your-line-channel-secret

# Market Data
MARKET_DATA_API_KEY=your-market-data-api-key

# App
APP_ENV=development
ANALYSIS_INTERVAL_MINUTES=5
CACHE_TTL_MINUTES=30
# Min hours between alerts for the same user+symbol (avoids re-firing a
# persistent setup every cycle). Default 24 = at most once per stock per day.
ALERT_COOLDOWN_HOURS=24
# Edge-triggered alerting: only alert when a signal newly turns active, not
# every cycle it stays active. Set to false to revert to level-triggered.
ALERT_EDGE_TRIGGER=true

# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
# LEGACY (HS256 only). Leave EMPTY for projects using the new asymmetric signing
# keys (ES256/RS256) — those are verified against the project's published JWKS
# automatically, no secret needed. Set this ONLY if your project still signs
# tokens with the legacy HS256 shared secret (Project Settings → API → JWT
# Secret). Setting it for an ES256 project will make every request 401.
SUPABASE_JWT_SECRET=

# OpenAI
OPENAI_API_KEY=your-openai-api-key
# Model for signal analysis + daily briefing. Default: gpt-5.6-luna.
# Cheaper alternatives: gpt-5.4-nano, gpt-4o-mini. See openai.com/api/docs/models.
OPENAI_MODEL=gpt-5.6-luna

# LINE Messaging API
LINE_CHANNEL_ACCESS_TOKEN=your-line-channel-access-token
# Required to verify inbound webhook signatures (account-linking flow). Set the
# webhook URL in the LINE console to: https://<your-backend>/api/v1/webhook/line
LINE_CHANNEL_SECRET=your-line-channel-secret
# Minutes an account-linking code stays valid (default 10).
LINE_LINK_CODE_TTL_MINUTES=10

# Market Data
MARKET_DATA_API_KEY=your-market-data-api-key

# App
APP_ENV=development
ANALYSIS_INTERVAL_MINUTES=5
CACHE_TTL_MINUTES=30
# Min hours between alerts for the same user+symbol (avoids re-firing a
# persistent setup every cycle). Default 24 = at most once per stock per day.
ALERT_COOLDOWN_HOURS=24
# Edge-triggered alerting: only alert when a signal newly turns active, not
# every cycle it stays active. Set to false to revert to level-triggered.
ALERT_EDGE_TRIGGER=true
# How long alerts are retained before the cleanup job deletes them.
ALERTS_RETENTION_DAYS=30

# Pipeline tuning
# Symbols analyzed in parallel per cycle (bounded to avoid Yahoo rate limits).
ANALYSIS_CONCURRENCY=5
# Min seconds between manual /analysis/trigger calls, per user. That endpoint
# fans out to every watched symbol and calls OpenAI, so it must not be loopable.
TRIGGER_COOLDOWN_SECONDS=300
# How long /market/chart responses are cached in-process.
CHART_CACHE_TTL_SECONDS=300

# Security
# Regex of allowed browser origins. Keep this narrow — a blanket
# `https://.*\.vercel\.app` would allow ANY Vercel-hosted site to call this API.
CORS_ALLOW_ORIGIN_REGEX=https://ai-stock-project[a-z0-9-]*\.vercel\.app
# Reverse proxies in front of the app (Railway/Render = 1). The rate limiter
# reads the client IP this many hops from the right of X-Forwarded-For; entries
# further left are supplied by the client and must not be trusted.
TRUSTED_PROXY_HOPS=1

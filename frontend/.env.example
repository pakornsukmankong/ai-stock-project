NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key
NEXT_PUBLIC_API_URL=http://localhost:8000

# Public site URL — used for OAuth redirects and social-share (Open Graph) meta.
# Defaults to the production URL if unset. Example: https://your-app.vercel.app
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Add-friend link for your LINE Official Account (Settings page "Add LINE OA" button).
# Get it from LINE Official Account Manager. Example: https://lin.ee/xxxxxxx
NEXT_PUBLIC_LINE_OA_ADD_URL=
